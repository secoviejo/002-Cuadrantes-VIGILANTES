# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVO DE EJEMPLO - NO CONTIENE CREDENCIALES REALES
# Copia este archivo a .env y ajusta los valores para tu entorno local.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Puerto y host del servidor Express (desarrollo local)
PORT=4000
HOST=127.0.0.1
NODE_ENV=development

# Origen permitido del frontend (Vite por defecto en el puerto 5173)
FRONTEND_ORIGIN=http://127.0.0.1:5173

# URL de conexión a la base de datos MariaDB de desarrollo
# Formato: mysql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BASE_DATOS
# IMPORTANTE: usa una base de datos de desarrollo, nunca producción.
# Ejemplo orientativo (cambia usuario, password y nombre si lo deseas):
DATABASE_URL="mysql://cuadrantes_user:CAMBIAR_PASSWORD_LOCAL@localhost:3306/cuadrantes_vigilantes_dev"

# Secreto para firmar tokens JWT (cambia este valor por uno seguro en producción)
JWT_SECRET="cambiar_en_produccion"
